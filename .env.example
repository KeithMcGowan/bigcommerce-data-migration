# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

# Found in your BigCommerce store URL: mystore.mybigcommerce.com/manage
# or under API > Store-Level API Accounts in the control panel.
STORE_HASH=your_store_hash_here

# X-Auth-Token from a Store-Level API Account with content read/write scope.
AUTH_TOKEN=your_x_auth_token_here

# The channel ID you want to copy widget templates FROM (your main/source channel).
# Find channel IDs under Channel Manager in the control panel,
# or via GET /v3/channels in the API.
SOURCE_CHANNEL_ID=1

# The channel ID you want to copy widget templates INTO (your new/destination channel).
DEST_CHANNEL_ID=2
